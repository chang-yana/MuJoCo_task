<mujoco model="panda scene with table and objects">

  <include file="panda_with_sensors.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    
    <material name="red_block" rgba="0.8 0.2 0.2 1"/>
    <material name="table_mat" rgba="0.5 0.4 0.3 0.9"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    
    <!-- 地面（禁用碰撞） -->
    <geom name="floor" type="plane" size="0 0 0.05" material="groundplane" contype="0" conaffinity="0"/>
    
    <!-- 桌子腿 -->
    <body name="table_leg_1" pos="0.3 -0.45 0.18">
      <geom type="box" size="0.05 0.05 0.18" rgba="0.4 0.3 0.2 1" contype="0" conaffinity="0"/>
    </body>
    <body name="table_leg_2" pos="0.9 -0.45 0.18">
      <geom type="box" size="0.05 0.05 0.18" rgba="0.4 0.3 0.2 1" contype="0" conaffinity="0"/>
    </body>
    <body name="table_leg_3" pos="0.3 0.45 0.18">
      <geom type="box" size="0.05 0.05 0.18" rgba="0.4 0.3 0.2 1" contype="0" conaffinity="0"/>
    </body>
    <body name="table_leg_4" pos="0.9 0.45 0.18">
      <geom type="box" size="0.05 0.05 0.18" rgba="0.4 0.3 0.2 1" contype="0" conaffinity="0"/>
    </body>
    
    <!-- 桌面 -->
    <body name="table" pos="0.65 0 0.35" mocap="true">
      <geom name="table_top" type="box" size="0.5 0.6 0.03" 
            material="table_mat" rgba="0.5 0.4 0.3 0.9"
            friction="0.8 0.2 0.1" condim="3"/>
    </body>

    <!-- ========== 红色正方体 ========== -->
    <body name="red_cube" pos="0.5 0 0.42">
      <geom name="red_cube_geom" type="box" size="0.04 0.04 0.04" 
            material="red_block" rgba="0.8 0.2 0.2 1"
            mass="0.1" friction="0.7 0.1 0.1" condim="3"/>
      <joint name="red_cube_joint" type="free" damping="0.1"/>
    </body>

  </worldbody>

  <!-- 接触配置 -->
  <contact>
    <exclude body1="table" body2="table_leg_1"/>
    <exclude body1="table" body2="table_leg_2"/>
    <exclude body1="table" body2="table_leg_3"/>
    <exclude body1="table" body2="table_leg_4"/>
  </contact>

  <!-- 传感器 - 红色立方体 -->
  <sensor>
    <framepos name="red_cube_pos" objtype="body" objname="red_cube"/>
    <framepos name="hand_pos" objtype="body" objname="hand"/>
  </sensor>

  <option integrator="implicitfast" gravity="0 0 -9.81" timestep="0.002">
    <flag contact="enable"/>
  </option>
</mujoco>
